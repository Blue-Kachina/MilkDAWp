{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev-win",
      "displayName": "Developer (Windows)",
      "description": "Local dev on Windows with plugin enabled and tests off by default",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build-win",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-dynamic",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-win/vcpkg_installed",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL",
        "MILKDAWP_BUILD_PLUGIN": "ON",
        "BUILD_TESTING": "OFF",
        "MILKDAWP_WITH_PROJECTM": "ON",
        "MILKDAWP_VST3_OVERRIDE_COPY_DIR": "$env{LOCALAPPDATA}/Programs/Common/VST3"
      }
    },
    {
      "name": "dev-mac",
      "displayName": "Developer (macOS)",
      "description": "Local dev on macOS universal build",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build-mac",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-osx-dynamic",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-mac/vcpkg_installed",
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0",
        "MILKDAWP_BUILD_PLUGIN": "ON",
        "BUILD_TESTING": "OFF",
        "MILKDAWP_WITH_PROJECTM": "ON"
      }
    },
    {
      "name": "ci-linux",
      "displayName": "CI (Linux, tests only)",
      "description": "Headless CI build: disable plugin, enable tests",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-ci",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-ci/vcpkg_installed",
        "MILKDAWP_BUILD_PLUGIN": "OFF",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "release-win",
      "displayName": "Release (Windows, plugin)",
      "description": "Plugin-only build for Windows releases and CI; no tests, no local VST3 install",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build-win-release",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-dynamic",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-win-release/vcpkg_installed",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL",
        "MILKDAWP_BUILD_PLUGIN": "ON",
        "BUILD_TESTING": "OFF",
        "MILKDAWP_WITH_PROJECTM": "ON"
      }
    },
    {
      "name": "release-mac",
      "displayName": "Release (macOS, plugin)",
      "description": "Plugin-only build for macOS releases and CI; ARM64, no tests",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build-mac-release",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "arm64-osx-dynamic",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-mac-release/vcpkg_installed",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0",
        "MILKDAWP_BUILD_PLUGIN": "ON",
        "BUILD_TESTING": "OFF",
        "MILKDAWP_WITH_PROJECTM": "ON"
      }
    },
    {
      "name": "release-linux",
      "displayName": "Release (Linux, plugin)",
      "description": "Plugin-only build for Linux releases and CI; no tests",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-ci-plugin",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/build-ci-plugin/vcpkg_installed",
        "CMAKE_BUILD_TYPE": "Release",
        "MILKDAWP_BUILD_PLUGIN": "ON",
        "BUILD_TESTING": "OFF",
        "MILKDAWP_WITH_PROJECTM": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev-win-Release", "configurePreset": "dev-win", "configuration": "Release" },
    { "name": "dev-win-Debug",   "configurePreset": "dev-win", "configuration": "Debug" },
    { "name": "dev-mac-Release", "configurePreset": "dev-mac", "configuration": "Release" },
    { "name": "dev-mac-Debug",   "configurePreset": "dev-mac", "configuration": "Debug" },
    { "name": "ci-linux-RelWithDebInfo", "configurePreset": "ci-linux", "configuration": "RelWithDebInfo" },
    { "name": "ci-linux-Debug", "configurePreset": "ci-linux", "configuration": "Debug" },
    { "name": "release-win-Release",   "configurePreset": "release-win",   "configuration": "Release" },
    { "name": "release-mac-Release",   "configurePreset": "release-mac",   "configuration": "Release" },
    { "name": "release-linux-Release", "configurePreset": "release-linux", "configuration": "Release" }
  ],
  "testPresets": [
    {
      "name": "ci-tests",
      "configurePreset": "ci-linux",
      "configuration": "RelWithDebInfo",
      "output": { "outputOnFailure": true }
    }
  ]
}
